# ==============================================================================
# Core application URLs and session secrets
# ==============================================================================
# Public URL for the main Next.js app.
# Local:  http://localhost:3000
# Azure:  https://<your-app-hostname>
NEXTAUTH_URL=http://localhost:3000

# Random secret used to sign session cookies and auth state.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=replace-with-a-long-random-base64-secret

# Internal docs origin used by the main app to proxy /docs to the Astro sidecar.
# Local dev should point to the Starlight dev server.
# In Azure Container Apps this will normally be the sidecar's localhost port.
DOCS_PROXY_ORIGIN=http://127.0.0.1:4321

# Optional default landing path after auth succeeds.
NEXT_PUBLIC_DEFAULT_APP_PATH=/maude

# Secret used to sign Teams deep-link state tokens for /tab/explorer.
# Falls back to NEXTAUTH_SECRET if omitted, but keeping it separate makes the
# Teams integration easier to rotate independently.
TEAMS_TAB_CONTEXT_SECRET=replace-with-a-dedicated-teams-state-secret

# ==============================================================================
# Microsoft Entra ID (app-level web authentication)
# ==============================================================================
# Tenant / directory ID for the target Entra tenant.
AZURE_AD_TENANT_ID=00000000-0000-0000-0000-000000000000

# Application (client) ID from the Entra app registration created for this app.
AZURE_AD_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Client secret for the Entra app registration.
# Store in Azure Key Vault in production; never expose to the browser.
AZURE_AD_CLIENT_SECRET=replace-with-the-app-registration-client-secret

# ==============================================================================
# OpenAI (current primary provider)
# ==============================================================================
# Server-side API key for the current OpenAI deployment target.
OPENAI_API_KEY=sk-...

# Optional model overrides. Leave the defaults unless you are intentionally
# changing the orchestration strategy.
OPENAI_FAST_MODEL=gpt-4.1-mini
OPENAI_STRONG_MODEL=gpt-4.1
OPENAI_BLENDED_MODE_NAME=blended

# ==============================================================================
# MotherDuck MCP access (core chat/runtime)
# ==============================================================================
# Primary MotherDuck token used by the MCP client for schema discovery, SQL
# execution, and Dive lifecycle operations.
MOTHERDUCK_TOKEN=md_...

# ==============================================================================
# MotherDuck Dive embedding (server-side only)
# ==============================================================================
# Business-plan admin token used ONLY by the backend to create short-lived embed
# sessions for live Dives. Never expose this in client-side code.
MOTHERDUCK_DIVE_ADMIN_TOKEN=md_admin_...

# Dedicated service-account username that should execute embedded Dive queries.
# This account should be scoped only to the data required for embedded Dives.
MOTHERDUCK_DIVE_SERVICE_ACCOUNT_USERNAME=service-account-name

# Comma-separated database allowlist used by API-side guardrails before tool calls.
# Keep this tightly scoped in production (for example: za_edw_pov).
MOTHERDUCK_ALLOWED_DATABASES=za_edw_pov

# Preferred default MotherDuck database for prompts and MCP preflight checks.
MOTHERDUCK_DEFAULT_DATABASE=za_edw_pov

# Metadata file loaded by the chat API for schema/business context hints.
# Relative paths resolve from the repository root in local/dev and container runtime.
MOTHERDUCK_METADATA_FILE=metadata/za_edw_pov.md

# Prompt audience label used in standalone query instruction wrapping.
# Keep this business-facing (for example: "Saint Louis Zoo business stakeholders").
MOTHERDUCK_CONTEXT_AUDIENCE=Saint Louis Zoo business stakeholders

# ==============================================================================
# PostgreSQL report store
# ==============================================================================
# Preferred neutral name for the report/share database connection string.
POSTGRES_DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Backward-compatibility alias used by older helpers in this codebase.
# Keep this in sync with POSTGRES_DATABASE_URL until the migration away from the
# legacy name is complete.
PLANETSCALE_DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ==============================================================================
# Azure runtime and secret-management placeholders
# ==============================================================================
# Optional documentation placeholders for Azure-hosted deployments.
# In production, prefer Container Apps secret refs and Key Vault integration.
AZURE_SUBSCRIPTION_ID=17dd17fe-f814-44bb-828f-c37c07db5a4f
AZURE_LOCATION=eastus2
KEY_VAULT_URI=https://your-key-vault-name.vault.azure.net/

# If you later choose user-assigned managed identity for Key Vault access, place
# the identity client ID here. Leave blank for system-assigned identity.
AZURE_CLIENT_ID=

# Teams / tab delivery contract (Stage 1 baseline)
# Teams app package ID from Developer Portal (per-environment).
TEAMS_APP_ID=

# Bot registration app ID used by Teams manifest "bots[].botId".
TEAMS_BOT_ID=

# Public host used by Teams manifests and default webApplicationInfo.resource.
APP_DOMAIN=your-container-app.azurecontainerapps.io

# Teams tab SSO Entra app (webApplicationInfo.id). This can match
# AZURE_AD_CLIENT_ID for single-registration setups, or point to a dedicated tab app.
TEAMS_TAB_AAD_APP_ID=

# API Application ID URI for Teams SSO/OBO. If blank, runtime falls back to:
# api://${APP_DOMAIN}/${TEAMS_TAB_AAD_APP_ID or AZURE_AD_CLIENT_ID}
TEAMS_API_APPLICATION_ID_URI=

# Confidential app identity used for OBO. If blank, runtime falls back to AZURE_AD_*.
TEAMS_OBO_CLIENT_ID=
TEAMS_OBO_CLIENT_SECRET=

# Comma-separated allowlist of accepted incoming Teams SSO token audiences.
# Keep this tight (for example: <teams-tab-app-id>,<api-app-id>).
TEAMS_SSO_ALLOWED_AUDIENCES=

# Space-separated least-privilege downstream scopes for OBO.
# Example for Microsoft Graph profile basics: "User.Read"
TEAMS_OBO_SCOPES=User.Read

# ==============================================================================
# Future Azure AI Foundry path (planned, not required for current OpenAI run)
# ==============================================================================
# These are intentionally present now so the eventual cutover does not require a
# brand-new environment contract.
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_API_KEY=
AZURE_AI_FOUNDRY_FAST_DEPLOYMENT=
AZURE_AI_FOUNDRY_STRONG_DEPLOYMENT=
AZURE_AI_FOUNDRY_API_VERSION=2024-10-21
