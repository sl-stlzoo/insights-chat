{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "prefix": {
      "value": "maude"
    },
    "environmentName": {
      "value": "dev"
    },
    "location": {
      "value": "eastus2"
    },
    "publicAppUrl": {
      "value": "https://replace-me-with-your-app-hostname"
    },
    "azureAdTenantId": {
      "value": "00000000-0000-0000-0000-000000000000"
    },
    "azureAdClientId": {
      "value": "00000000-0000-0000-0000-000000000000"
    },
    "teamsAppId": {
      "value": "00000000-0000-0000-0000-000000000000"
    },
    "teamsBotId": {
      "value": "00000000-0000-0000-0000-000000000000"
    },
    "teamsTabAadAppId": {
      "value": "00000000-0000-0000-0000-000000000000"
    },
    "teamsApiApplicationIdUri": {
      "value": "api://your-container-app.azurecontainerapps.io/00000000-0000-0000-0000-000000000000"
    },
    "teamsOboClientId": {
      "value": "00000000-0000-0000-0000-000000000000"
    },
    "teamsOboClientSecret": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subId>/resourceGroups/<rg>/providers/Microsoft.KeyVault/vaults/<vaultName>"
        },
        "secretName": "teams-obo-client-secret"
      }
    },
    "teamsOboScopes": {
      "value": "User.Read"
    },
    "teamsSsoAllowedAudiences": {
      "value": "00000000-0000-0000-0000-000000000000"
    },
    "azureAdClientSecret": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subId>/resourceGroups/<rg>/providers/Microsoft.KeyVault/vaults/<vaultName>"
        },
        "secretName": "azure-ad-client-secret"
      }
    },
    "nextAuthSecret": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subId>/resourceGroups/<rg>/providers/Microsoft.KeyVault/vaults/<vaultName>"
        },
        "secretName": "nextauth-secret"
      }
    },
    "openAiApiKey": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subId>/resourceGroups/<rg>/providers/Microsoft.KeyVault/vaults/<vaultName>"
        },
        "secretName": "openai-api-key"
      }
    },
    "motherDuckToken": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subId>/resourceGroups/<rg>/providers/Microsoft.KeyVault/vaults/<vaultName>"
        },
        "secretName": "motherduck-token"
      }
    },
    "motherDuckDiveAdminToken": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subId>/resourceGroups/<rg>/providers/Microsoft.KeyVault/vaults/<vaultName>"
        },
        "secretName": "motherduck-dive-admin-token"
      }
    },
    "motherDuckDiveServiceAccountUsername": {
      "value": "service-account-name"
    },
    "motherDuckAllowedDatabases": {
      "value": "za_edw_pov"
    },
    "motherDuckDefaultDatabase": {
      "value": "za_edw_pov"
    },
    "motherDuckMetadataFile": {
      "value": "metadata/za_edw_pov.md"
    },
    "motherDuckContextAudience": {
      "value": "Saint Louis Zoo business stakeholders"
    },
    "postgresAdminPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<subId>/resourceGroups/<rg>/providers/Microsoft.KeyVault/vaults/<vaultName>"
        },
        "secretName": "postgres-admin-password"
      }
    },
    "webContainerImage": {
      "value": "replace-with-acr-login-server/maude-web:latest"
    },
    "docsContainerImage": {
      "value": "replace-with-acr-login-server/maude-docs:latest"
    }
  }
}
