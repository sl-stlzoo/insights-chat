# ==============================================================================
# Docs site routing
# ==============================================================================
# The docs sidecar is intended to live under /docs behind the main app proxy.
PUBLIC_DOCS_BASE_PATH=/docs

# Optional absolute public URL used when previewing canonical links or sitemap-
# style metadata locally.
PUBLIC_DOCS_SITE_URL=http://localhost:4321/docs

# ==============================================================================
# Search configuration
# ==============================================================================
# The current docs build uses a local Orama-generated JSON index and does not
# require hosted search credentials.
PUBLIC_DOCS_SEARCH_MODE=local

# Optional future Orama Cloud placeholders if the docs experience later moves to
# a hosted index instead of the in-repo generated JSON index.
ORAMA_CLOUD_ENDPOINT=
ORAMA_CLOUD_PUBLIC_API_KEY=
ORAMA_CLOUD_INDEX_ID=
