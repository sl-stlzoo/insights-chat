---
const searchHref = `${import.meta.env.BASE_URL}search/`;
---

<a class="docs-search-link" href={searchHref}>
  Search docs
</a>

<style>
  .docs-search-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.9rem;
    border-radius: 0.5rem;
    border: 1px solid #94a3b8;
    background: #ffffff;
    color: #0f172a;
    font-size: 0.94rem;
    font-weight: 600;
    text-decoration: none;
  }

  .docs-search-link:hover {
    background: #f8fafc;
    border-color: #475569;
    color: #0f172a;
  }

  .docs-search-link:focus-visible {
    outline: 2px solid #00538b;
    outline-offset: 2px;
  }

  :root[data-theme='dark'] .docs-search-link {
    border-color: #64748b;
    background: #111a2a;
    color: #f1f5f9;
  }

  :root[data-theme='dark'] .docs-search-link:hover {
    border-color: #94a3b8;
    background: #0b1220;
    color: #f1f5f9;
  }
</style>
