{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.16/MicrosoftTeams.schema.json",
  "manifestVersion": "1.16",
  "id": "${TEAMS_PROD_APP_ID}",
  "version": "1.2.0",
  "packageName": "com.enterprise.maude.analytics.prod",
  "developer": {
    "name": "Enterprise Analytics",
    "websiteUrl": "https://${TEAMS_PROD_APP_DOMAIN}",
    "privacyUrl": "https://${TEAMS_PROD_APP_DOMAIN}/docs",
    "termsOfUseUrl": "https://${TEAMS_PROD_APP_DOMAIN}/docs"
  },
  "name": {
    "short": "Maude",
    "full": "Maude Analytics Assistant"
  },
  "description": {
    "short": "Secure MotherDuck analytics assistant.",
    "full": "Production Teams package for tab-first analytics with Entra SSO and backend OBO."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#005589",
  "defaultInstallScope": "personal",
  "staticTabs": [
    {
      "entityId": "maudeDiveViewerTab",
      "name": "Data Explorer Workspace",
      "contentUrl": "https://${TEAMS_PROD_APP_DOMAIN}/tab/explorer",
      "websiteUrl": "https://${TEAMS_PROD_APP_DOMAIN}/tab/explorer",
      "scopes": ["personal"]
    }
  ],
  "bots": [
    {
      "botId": "${TEAMS_PROD_BOT_ID}",
      "scopes": ["personal", "team"],
      "supportsFiles": false,
      "isNotificationOnly": false
    }
  ],
  "permissions": ["identity"],
  "validDomains": ["${TEAMS_PROD_APP_DOMAIN}"],
  "webApplicationInfo": {
    "id": "${TEAMS_PROD_TAB_AAD_APP_ID}",
    "resource": "${TEAMS_PROD_API_APPLICATION_ID_URI}"
  }
}
